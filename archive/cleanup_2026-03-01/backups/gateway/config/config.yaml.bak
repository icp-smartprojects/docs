    retry_delay: 1s
  
  file_scanner:
    url: http://file-scanner:52009
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  shape_recognition:
    url: http://shape-engine:52010
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  pattern_genome:
    url: http://pattern-genome:52011
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  signal_engine:
    url: http://signal-engine:52012
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  multi_tf_consensus:
    url: http://multi-tf-consensus:52013
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  execution_engine:
    url: http://execution-engine:52014
    health_endpoint: /health
    timeout: 30s
