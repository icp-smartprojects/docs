  demo_system:
    url: http://demo-system:52022
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s

rate_limit:
  enabled: true
  requests_per: 100
  window_size: 1m
  burst_size: 20
  role_limits:
    admin: 1000
    trader: 500
    viewer: 100

cors:
  enabled: true
  allowed_origins:
    - "http://localhost:52000"
    - "http://localhost:3000"
    - "http://localhost"
    - "http://127.0.0.1"
    - "http://0.0.0.0"
  allowed_methods:
    - GET
    - POST
    - PUT
    - DELETE
    - PATCH
    - OPTIONS
  allowed_headers:
    - Origin
    - Content-Type
    - Accept
    - Authorization
    - X-Request-ID
    - X-Correlation-ID
  exposed_headers:
    - X-Request-ID
    - X-Correlation-ID
  allow_credentials: true
  max_age: 3600

circuit_breaker:
  enabled: true
  threshold: 5
  timeout: 60s
  max_concurrent: 100
  volume_threshold: 20
  error_percentage: 50

tracing:
  enabled: true
  service_name: api-gateway
  jaeger_url: http://jaeger:14268/api/traces
  sampling_rate: 0.1

metrics:
  enabled: true
  port: "9090"
  path: /metrics

websocket:
  enabled: true
  path: /ws/semantic-stream
  read_buffer_size: 1024
  write_buffer_size: 1024
  ping_interval: 30s
  pong_wait: 60s
  write_wait: 10s
  max_message_size: 512000
  enable_compression: true

timeouts:
  read: 30s
  write: 30s
  idle: 120s
  shutdown: 15s
  service_call: 30s

logging:
  level: info
  format: json
  output: stdout
  max_size: 100
  max_backups: 3
  max_age: 7
  compress: true
