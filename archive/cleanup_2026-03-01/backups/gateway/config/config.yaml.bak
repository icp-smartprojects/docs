environment: development
service_name: api-gateway
port: "52031"

auth:
  enabled: true
  jwt_secret: "dev-secret-change-in-production"
  jwt_expiration: 15m
  refresh_enabled: true
  refresh_ttl: 168h
  access_control_url: http://access-control:52008

services:
  ingestion_engine:
    url: http://market-ingestion:52010
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
    load_balancing: round-robin

  auth_service:
    url: http://auth-service:5500
    health_endpoint: /health
    timeout: 15s
    retry_count: 3
    retry_delay: 1s
    load_balancing: none
    circuit_breaker:
      enabled: true
      failure_threshold: 5
      reset_timeout: 30s
  
  perception_engine:
    url: http://perception:52012
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  meaning_engine:
    url: http://meaning-engine:52003
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  learning_engine:
    url: http://learning-engine:52004
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
