    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  language_engine:
    url: http://language-intelligence:52006
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  cyber_guard:
