    retry_delay: 1s
  
  semantic_memory:
    url: http://knowledge-graph:52015
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  book_reader:
    url: http://memory:52018
    health_endpoint: /health
    timeout: 30s
    retry_count: 3
    retry_delay: 1s
  
  conversation_engine:
    url: http://conversation-engine:52017
    health_endpoint: /health
    timeout: 30s
