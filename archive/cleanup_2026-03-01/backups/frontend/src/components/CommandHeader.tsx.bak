/**
 * AUREXIS COMMAND HEADER
 * Military-grade top bar with system status, time, latency, user controls
 */
import { useState, useEffect, useCallback } from 'react';
import { useNavigate } from 'react-router-dom';
import {
  Bell,
  Search,
  Settings,
  LogOut,
  User,
  Zap,
  Clock,
  ChevronDown,
  Shield,
  Activity,
  Wifi,
  WifiOff,
  AlertTriangle,
} from 'lucide-react';
import { useAuth } from '@/hooks/useAuth';

interface ServiceStatus {
  name: string;
  status: 'UP' | 'DEGRADED' | 'DOWN';
  latency: number;
}

interface CommandHeaderProps {
  isCollapsed: boolean;
}

export default function CommandHeader({ isCollapsed }: CommandHeaderProps) {
  const navigate = useNavigate();
  const { user, logout } = useAuth();
  const [timeNow, setTimeNow] = useState(new Date());
  const [showUserMenu, setShowUserMenu] = useState(false);
  const [notifications] = useState(3);
  const [systemLatency, setSystemLatency] = useState(0);
  const [servicesOnline, setServicesOnline] = useState(0);
  const [totalServices] = useState(12);

  // Clock
  useEffect(() => {
    const timer = setInterval(() => setTimeNow(new Date()), 1000);
    return () => clearInterval(timer);
  }, []);

  // System latency probe
  useEffect(() => {
    const probe = async () => {
      const start = performance.now();
      try {
        await fetch('http://localhost:52040/health', { signal: AbortSignal.timeout(3000) });
        setSystemLatency(Math.round(performance.now() - start));
        setServicesOnline((prev) => Math.max(prev, 1));
      } catch {
        setSystemLatency(0);
      }
    };

    probe();
    const interval = setInterval(probe, 10000);
    return () => clearInterval(interval);
  }, []);

  const userInitials = user?.username
    ? user.username.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2)
    : 'AD';

  const handleLogout = useCallback(async () => {
    setShowUserMenu(false);
    await logout();
    navigate('/login');
  }, [logout, navigate]);

  return (
    <div className={`aurexis-header ${isCollapsed ? 'collapsed' : ''}`}>
      {/* Left – System Status Badges */}
      <div className="header-status-group">
        {/* System Live */}
        <div className="header-status-badge">
          <span className={`dot ${servicesOnline > 0 ? 'green' : 'red'}`} />
          <span style={{ color: 'var(--mil-text-primary)', fontWeight: 600 }}>
            {servicesOnline > 0 ? 'SYSTEM LIVE' : 'OFFLINE'}
          </span>
        </div>

        {/* Clock */}
        <div className="header-status-badge">
          <Clock size={12} style={{ color: 'var(--mil-text-tertiary)' }} />
          <span>
            {timeNow.toLocaleTimeString('en-US', { hour12: false })}
          </span>
        </div>

        {/* Latency */}
        {systemLatency > 0 && (
          <div className="header-status-badge">
            <Zap size={12} style={{ color: 'var(--mil-cyan)' }} />
            <span style={{ color: 'var(--mil-cyan)' }}>{systemLatency}ms</span>
          </div>
        )}

        {/* Services Status */}
        <div className="header-status-badge">
          <Activity size={12} />
          <span>{servicesOnline}/{totalServices} services</span>
        </div>
      </div>

      {/* Right – Actions */}
      <div className="header-actions">
        {/* Search */}
        <button className="header-icon-btn" title="Search">
          <Search size={16} />
        </button>

        {/* Notifications */}
        <button className="header-icon-btn" title="Notifications">
          <Bell size={16} />
          {notifications > 0 && <span className="notification-dot" />}
        </button>

        {/* Settings */}
        <button className="header-icon-btn" title="Settings" onClick={() => navigate('/monitoring')}>
          <Settings size={16} />
        </button>

        {/* User Menu */}
        <div style={{ position: 'relative' }}>
          <button
            className="header-user-menu"
            onClick={() => setShowUserMenu(!showUserMenu)}
          >
            <div className="header-user-avatar">{userInitials}</div>
            <div className="header-user-info">
              <span className="header-user-name">{user?.username || 'Admin'}</span>
              <span className="header-user-role">{user?.role || 'System Admin'}</span>
            </div>
            <ChevronDown size={12} style={{ color: 'var(--mil-text-tertiary)' }} />
          </button>

          {/* Dropdown */}
          {showUserMenu && (
            <div style={{
              position: 'absolute',
              right: 0,
              top: '100%',
              marginTop: '0.5rem',
              background: 'var(--mil-bg-card)',
              border: '1px solid var(--mil-border)',
              borderRadius: 'var(--mil-radius-lg)',
              minWidth: '200px',
              boxShadow: 'var(--mil-shadow-lg)',
              zIndex: 50,
              overflow: 'hidden',
            }}>
              <button
                onClick={() => { setShowUserMenu(false); navigate('/monitoring'); }}
                style={{
                  width: '100%',
                  display: 'flex',
                  alignItems: 'center',
                  gap: '0.75rem',
                  padding: '0.625rem 1rem',
                  background: 'transparent',
                  border: 'none',
                  color: 'var(--mil-text-secondary)',
                  fontSize: '0.8125rem',
                  cursor: 'pointer',
                  transition: 'background 200ms',
                }}
                onMouseEnter={(e) => (e.currentTarget.style.background = 'var(--mil-bg-hover)')}
                onMouseLeave={(e) => (e.currentTarget.style.background = 'transparent')}
              >
                <User size={14} />
                <span>Profile & Settings</span>
              </button>
              <button
                onClick={() => { setShowUserMenu(false); navigate('/monitoring'); }}
                style={{
                  width: '100%',
                  display: 'flex',
                  alignItems: 'center',
                  gap: '0.75rem',
                  padding: '0.625rem 1rem',
                  background: 'transparent',
                  border: 'none',
                  color: 'var(--mil-text-secondary)',
                  fontSize: '0.8125rem',
                  cursor: 'pointer',
                }}
                onMouseEnter={(e) => (e.currentTarget.style.background = 'var(--mil-bg-hover)')}
                onMouseLeave={(e) => (e.currentTarget.style.background = 'transparent')}
              >
                <Shield size={14} />
                <span>Authentication</span>
              </button>
              <div style={{ borderTop: '1px solid var(--mil-border)' }}>
                <button
                  onClick={handleLogout}
                  style={{
                    width: '100%',
                    display: 'flex',
                    alignItems: 'center',
                    gap: '0.75rem',
                    padding: '0.625rem 1rem',
                    background: 'transparent',
                    border: 'none',
                    color: 'var(--mil-red)',
                    fontSize: '0.8125rem',
                    cursor: 'pointer',
                  }}
                  onMouseEnter={(e) => (e.currentTarget.style.background = 'var(--mil-bg-hover)')}
                  onMouseLeave={(e) => (e.currentTarget.style.background = 'transparent')}
                >
                  <LogOut size={14} />
                  <span>Sign Out</span>
                </button>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

export { CommandHeader };
