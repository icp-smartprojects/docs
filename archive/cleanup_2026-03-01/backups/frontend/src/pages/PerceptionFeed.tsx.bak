/**
 * PERCEPTION FEED PAGE
 * 
 * Perception is "what the machine noticed".
 * 
 * Shows:
 * - Event stream: "liquidity taken", "BOS detected", "gap formed", "mitigation"
 * - Filter by timeframe/symbol/event-type
 * - Evidence preview: which candles triggered it
 * 
 * Backed by:
 * - perception (event processor)
 * - event-bus (delivery)
 * - ontology (event schema/types)
 */

import { useEffect, useState, useRef } from 'react';
import { AurexisLayout } from '@/layouts/AurexisLayout';
import gatewayApi, { gatewayStreamEndpoints } from '@/services/api/gatewayApi';
import { Activity, Eye, Filter, Clock, Target, TrendingUp } from 'lucide-react';

const EVENT_TYPES = [
  'LIQUIDITY_TAKEN', 'BOS_DETECTED', 'CHOCH_DETECTED', 'GAP_FORMED',
  'FVG_CREATED', 'SWING_DETECTED', 'MITIGATION_COMPLETE', 'STRUCTURE_BREAK'
];

const TIMEFRAMES = ['1m', '5m', '15m', '1h', '4h', '1D', 'HTF'];

interface PerceptionEvent {
  id: string;
  eventType: string;
  symbol: string;
  timeframe: string;
  timestamp: string;
  confidence: number;
  metadata: {
    price: number;
    description: string;
    significance: 'low' | 'medium' | 'high';
  };
  evidence: {
    candleIds: string[];
    anchorPoints: any[];
  };
}

export default function PerceptionFeedPage() {
  const [symbol, setSymbol] = useState('BTCUSD');
  const [events, setEvents] = useState<PerceptionEvent[]>([]);
  const [selectedEvent, setSelectedEvent] = useState<PerceptionEvent | null>(null);
  const [filters, setFilters] = useState<{
    timeframe?: string;
    eventType?: string;
  }>({});
  const [autoScroll, setAutoScroll] = useState(true);
  
  const eventSourceRef = useRef<EventSource | null>(null);
  const eventsContainerRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    loadEvents();
    setupRealTimeStream();

    return () => {
      if (eventSourceRef.current) {
        eventSourceRef.current.close();
      }
    };
  }, [symbol, filters]);

  useEffect(() => {
    if (autoScroll && eventsContainerRef.current) {
      eventsContainerRef.current.scrollTop = 0;
    }
  }, [events]);

  async function loadEvents() {
    try {
      const response = await gatewayApi.getPerceptionEvents(
        symbol,
        filters.timeframe,
        filters.eventType,
        100
      );
      setEvents(response.data.events);
    } catch (error) {
      console.error('[PerceptionFeed] Failed to load events:', error);
    }
  }

  function setupRealTimeStream() {
    const streamUrl = gatewayStreamEndpoints.perceptionStream(symbol, filters.timeframe);
    const eventSource = new EventSource(streamUrl);

    eventSource.onmessage = (event) => {
      const data = JSON.parse(event.data);
      
      if (data.type === 'perception_event') {
        // Apply filters
        if (filters.eventType && data.event.eventType !== filters.eventType) return;
        
        setEvents((prev) => [data.event, ...prev].slice(0, 100));
      }
    };

    eventSource.onerror = (error) => {
      console.error('[PerceptionFeed] Stream error:', error);
      eventSource.close();
      setTimeout(setupRealTimeStream, 5000);
    };

    eventSourceRef.current = eventSource;
  }

  async function handleEventClick(event: PerceptionEvent) {
    try {
      const response = await gatewayApi.getPerceptionEvent(event.id);
      setSelectedEvent(response.data);
    } catch (error) {
      console.error('[PerceptionFeed] Failed to load event details:', error);
    }
  }

  function getEventColor(event: PerceptionEvent): string {
    if (event.metadata.significance === 'high') return 'text-red-400 border-red-700';
    if (event.metadata.significance === 'medium') return 'text-yellow-400 border-yellow-700';
    return 'text-blue-400 border-blue-700';
  }

  function getEventIcon(eventType: string) {
    switch (eventType) {
      case 'LIQUIDITY_TAKEN':
        return <Target className="h-4 w-4" />;
      case 'BOS_DETECTED':
      case 'CHOCH_DETECTED':
        return <TrendingUp className="h-4 w-4" />;
      case 'GAP_FORMED':
      case 'FVG_CREATED':
        return <Activity className="h-4 w-4" />;
      default:
        return <Activity className="h-4 w-4" />;
    }
  }

  return (
    <AurexisLayout>
      <div className="grid grid-cols-12 gap-4">
        {/* Event Stream (8 cols) */}
        <div className="col-span-8 space-y-4">
          <div className="flex items-center justify-between">
            <div>
              <h1 className="text-3xl font-bold text-white">Perception Feed</h1>
              <p className="text-slate-400 mt-1">Semantic events • What the machine noticed</p>
            </div>

            <div className="flex items-center space-x-3">
              <label className="flex items-center space-x-2 text-sm text-slate-300">
                <input
                  type="checkbox"
                  checked={autoScroll}
                  onChange={(e) => setAutoScroll(e.target.checked)}
                  className="rounded"
                />
                <span>Auto-scroll</span>
              </label>

              <select
                value={symbol}
                onChange={(e) => setSymbol(e.target.value)}
                className="bg-slate-800 text-white px-4 py-2 rounded-lg border border-slate-700"
              >
                <option value="BTCUSD">BTC/USD</option>
                <option value="ETHUSD">ETH/USD</option>
              </select>
            </div>
          </div>

          {/* Filters */}
          <div className="bg-slate-800/50 border border-slate-700 rounded-lg p-4">
            <div className="flex items-center space-x-4">
              <Filter className="h-5 w-5 text-slate-400" />
              
              <select
                value={filters.timeframe || ''}
                onChange={(e) => setFilters({ ...filters, timeframe: e.target.value || undefined })}
                className="bg-slate-700 text-white px-3 py-2 rounded-lg text-sm"
              >
                <option value="">All Timeframes</option>
                {TIMEFRAMES.map((tf) => (
                  <option key={tf} value={tf}>{tf}</option>
                ))}
              </select>

              <select
                value={filters.eventType || ''}
                onChange={(e) => setFilters({ ...filters, eventType: e.target.value || undefined })}
                className="bg-slate-700 text-white px-3 py-2 rounded-lg text-sm"
              >
                <option value="">All Event Types</option>
                {EVENT_TYPES.map((type) => (
                  <option key={type} value={type}>{type.replace('_', ' ')}</option>
                ))}
              </select>

              <button
                onClick={() => setFilters({})}
                className="px-4 py-2 bg-slate-700 hover:bg-slate-600 text-white text-sm rounded-lg"
              >
                Clear Filters
              </button>
            </div>
          </div>

          {/* Event Stream */}
          <div 
            ref={eventsContainerRef}
            className="bg-slate-900 border border-slate-700 rounded-lg p-4 space-y-2 max-h-[800px] overflow-y-auto"
          >
            {events.length === 0 ? (
              <div className="text-center py-12 text-slate-400">
                <Activity className="h-12 w-12 mx-auto mb-3 text-slate-600" />
                <div>No events yet. Listening for perception events...</div>
              </div>
            ) : (
              events.map((event) => (
                <button
                  key={event.id}
                  onClick={() => handleEventClick(event)}
                  className={`w-full text-left bg-slate-800/50 border-l-4 hover:bg-slate-800 rounded p-4 transition-all ${getEventColor(event)}`}
                >
                  <div className="flex items-start justify-between">
                    <div className="flex items-start space-x-3 flex-1">
                      <div className={`mt-1 ${getEventColor(event)}`}>
                        {getEventIcon(event.eventType)}
                      </div>
                      
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center space-x-2 mb-1">
                          <span className="font-medium text-white">
                            {event.eventType.replace('_', ' ')}
                          </span>
                          <span className="text-xs px-2 py-0.5 bg-slate-700 rounded text-slate-300">
                            {event.timeframe}
                          </span>
                          <span className={`text-xs px-2 py-0.5 rounded ${
                            event.metadata.significance === 'high' ? 'bg-red-500/20 text-red-300' :
                            event.metadata.significance === 'medium' ? 'bg-yellow-500/20 text-yellow-300' :
                            'bg-blue-500/20 text-blue-300'
                          }`}>
                            {event.metadata.significance}
                          </span>
                        </div>
                        
                        <p className="text-sm text-slate-300 mb-2">
                          {event.metadata.description}
                        </p>

                        <div className="flex items-center space-x-4 text-xs text-slate-400">
                          <span className="flex items-center space-x-1">
                            <Clock className="h-3 w-3" />
                            <span>{new Date(event.timestamp).toLocaleTimeString()}</span>
                          </span>
                          <span>Price: ${event.metadata.price.toFixed(2)}</span>
                          <span>Confidence: {(event.confidence * 100).toFixed(1)}%</span>
                        </div>
                      </div>
                    </div>

                    <Eye className="h-4 w-4 text-slate-500" />
                  </div>
                </button>
              ))
            )}
          </div>
        </div>

        {/* Event Details Sidebar (4 cols) */}
        <div className="col-span-4">
          {selectedEvent ? (
            <div className="bg-slate-800/50 border border-slate-700 rounded-lg p-4 sticky top-4 space-y-4">
              <div className="flex items-center justify-between">
                <h3 className="text-lg font-bold text-white">Event Details</h3>
                <button
                  onClick={() => setSelectedEvent(null)}
                  className="text-slate-400 hover:text-white"
                >
                  ×
                </button>
              </div>

              <div className="space-y-3">
                <div>
                  <div className="text-xs text-slate-400">Event Type</div>
                  <div className="text-white font-medium">{selectedEvent.eventType.replace('_', ' ')}</div>
                </div>

                <div>
                  <div className="text-xs text-slate-400">Symbol / Timeframe</div>
                  <div className="text-white font-medium">{selectedEvent.symbol} • {selectedEvent.timeframe}</div>
                </div>

                <div>
                  <div className="text-xs text-slate-400">Timestamp</div>
                  <div className="text-white font-mono text-sm">
                    {new Date(selectedEvent.timestamp).toLocaleString()}
                  </div>
                </div>

                <div>
                  <div className="text-xs text-slate-400">Confidence</div>
                  <div className="flex items-center space-x-2">
                    <div className="flex-1 bg-slate-700 rounded-full h-2">
                      <div
                        className="bg-cyan-500 h-2 rounded-full"
                        style={{ width: `${selectedEvent.confidence * 100}%` }}
                      />
                    </div>
                    <span className="text-cyan-300 font-mono text-sm">
                      {(selectedEvent.confidence * 100).toFixed(1)}%
                    </span>
                  </div>
                </div>

                <div>
                  <div className="text-xs text-slate-400">Significance</div>
                  <div className={`inline-block px-3 py-1 rounded text-sm font-medium ${
                    selectedEvent.metadata.significance === 'high' ? 'bg-red-500/20 text-red-300' :
                    selectedEvent.metadata.significance === 'medium' ? 'bg-yellow-500/20 text-yellow-300' :
                    'bg-blue-500/20 text-blue-300'
                  }`}>
                    {selectedEvent.metadata.significance.toUpperCase()}
                  </div>
                </div>

                <div>
                  <div className="text-xs text-slate-400">Price at Event</div>
                  <div className="text-2xl font-bold text-white">${selectedEvent.metadata.price.toFixed(2)}</div>
                </div>

                <div>
                  <div className="text-xs text-slate-400 mb-2">Description</div>
                  <div className="text-sm text-slate-300 bg-slate-900/50 rounded p-3">
                    {selectedEvent.metadata.description}
                  </div>
                </div>

                <div>
                  <div className="text-xs text-slate-400 mb-2">Evidence</div>
                  <div className="bg-slate-900/50 rounded p-3 space-y-2">
                    <div className="text-sm">
                      <span className="text-slate-400">Candles:</span>
                      <span className="text-white ml-2">{selectedEvent.evidence.candleIds.length}</span>
                    </div>
                    <div className="text-sm">
                      <span className="text-slate-400">Anchor Points:</span>
                      <span className="text-white ml-2">{selectedEvent.evidence.anchorPoints.length}</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <div className="bg-slate-800/50 border border-slate-700 rounded-lg p-12 text-center sticky top-4">
              <Activity className="h-16 w-16 text-slate-600 mx-auto mb-4" />
              <div className="text-slate-400">Select an event to view details</div>
            </div>
          )}
        </div>
      </div>
    </AurexisLayout>
  );
}
