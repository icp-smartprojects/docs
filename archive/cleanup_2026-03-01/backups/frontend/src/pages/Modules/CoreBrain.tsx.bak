import { useState, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import { ArrowLeft, Activity, Brain, Cpu, Network, RefreshCw } from 'lucide-react';

interface ServiceStatus {
  status: string;
  service: string;
  timestamp?: number;
  message?: string;
}

interface SystemMetrics {
  activeConnections: number;
  messagesProcessed: number;
  uptime: string;
  memoryUsage: string;
}

export default function CoreBrain() {
  const navigate = useNavigate();
  const [status, setStatus] = useState<ServiceStatus | null>(null);
  const [metrics, setMetrics] = useState<SystemMetrics>({
    activeConnections: 0,
    messagesProcessed: 0,
    uptime: '0h 0m',
    memoryUsage: '0%'
  });
  const [isLoading, setIsLoading] = useState(true);
  const [logs, setLogs] = useState<string[]>([]);

  useEffect(() => {
    fetchStatus();
    const interval = setInterval(fetchStatus, 5000);
    return () => clearInterval(interval);
  }, []);

  const fetchStatus = async () => {
    try {
      const response = await fetch('http://localhost:52040/health');
      if (response.ok) {
        const data = await response.json();
        setStatus(data);
        // Simulate metrics
        setMetrics({
          activeConnections: Math.floor(Math.random() * 20) + 5,
          messagesProcessed: Math.floor(Math.random() * 10000) + 1000,
          uptime: `${Math.floor(Math.random() * 24)}h ${Math.floor(Math.random() * 60)}m`,
          memoryUsage: `${Math.floor(Math.random() * 40) + 30}%`
        });
        setLogs(prev => [...prev.slice(-9), `[${new Date().toLocaleTimeString()}] Core Brain health check: OK`]);
      } else {
        setStatus({ status: 'DOWN', service: 'core-brain', message: 'Service unavailable' });
        setLogs(prev => [...prev.slice(-9), `[${new Date().toLocaleTimeString()}] Core Brain health check: FAILED`]);
      }
    } catch (error) {
      setStatus({ status: 'DOWN', service: 'core-brain', message: 'Connection failed' });
      setLogs(prev => [...prev.slice(-9), `[${new Date().toLocaleTimeString()}] Core Brain connection error`]);
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <div style={{
      minHeight: '100vh',
      background: 'linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%)',
      color: 'white',
      fontFamily: 'Arial, sans-serif'
    }}>
      {/* Header */}
      <header style={{
        display: 'flex',
        alignItems: 'center',
        padding: '20px 40px',
        borderBottom: '2px solid #00ffff',
        background: 'rgba(0,0,0,0.5)'
      }}>
        <button
          onClick={() => navigate('/')}
          style={{
            background: 'transparent',
            border: '1px solid #00ffff',
            color: '#00ffff',
            padding: '10px 15px',
            borderRadius: '8px',
            cursor: 'pointer',
            display: 'flex',
            alignItems: 'center',
            gap: '8px',
            marginRight: '30px'
          }}
        >
          <ArrowLeft size={18} />
          Back
        </button>
        <Brain size={32} color="#00ffff" />
        <h1 style={{ marginLeft: '15px', color: '#00ffff', fontSize: '28px' }}>
          CORE BRAIN
        </h1>
        <div style={{ marginLeft: 'auto', display: 'flex', alignItems: 'center', gap: '15px' }}>
          <span style={{
            padding: '8px 16px',
            borderRadius: '20px',
            background: status?.status === 'UP' ? 'rgba(0,255,136,0.2)' : 'rgba(255,0,85,0.2)',
            border: `1px solid ${status?.status === 'UP' ? '#00ff88' : '#ff0055'}`,
            color: status?.status === 'UP' ? '#00ff88' : '#ff0055'
          }}>
            {status?.status === 'UP' ? '● ONLINE' : '● OFFLINE'}
          </span>
          <button onClick={fetchStatus} style={{
            background: 'transparent',
            border: '1px solid #00ffff',
            color: '#00ffff',
            padding: '8px',
            borderRadius: '8px',
            cursor: 'pointer'
          }}>
            <RefreshCw size={18} className={isLoading ? 'spinning' : ''} />
          </button>
        </div>
      </header>

      {/* Main Content */}
      <div style={{ padding: '40px', display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '30px' }}>
        {/* Metrics Cards */}
        <div style={{
          background: 'rgba(26,26,46,0.8)',
          borderRadius: '15px',
          padding: '30px',
          border: '1px solid #00ffff'
        }}>
          <h2 style={{ color: '#00ffff', marginBottom: '25px', display: 'flex', alignItems: 'center', gap: '10px' }}>
            <Activity size={24} />
            System Metrics
          </h2>
          <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '20px' }}>
            <div style={{ background: 'rgba(0,255,255,0.1)', padding: '20px', borderRadius: '10px' }}>
              <div style={{ color: '#888', fontSize: '14px' }}>Active Connections</div>
              <div style={{ color: '#00ffff', fontSize: '32px', fontWeight: 'bold' }}>{metrics.activeConnections}</div>
            </div>
            <div style={{ background: 'rgba(0,255,255,0.1)', padding: '20px', borderRadius: '10px' }}>
              <div style={{ color: '#888', fontSize: '14px' }}>Messages Processed</div>
              <div style={{ color: '#00ffff', fontSize: '32px', fontWeight: 'bold' }}>{metrics.messagesProcessed.toLocaleString()}</div>
            </div>
            <div style={{ background: 'rgba(0,255,255,0.1)', padding: '20px', borderRadius: '10px' }}>
              <div style={{ color: '#888', fontSize: '14px' }}>Uptime</div>
              <div style={{ color: '#00ff88', fontSize: '32px', fontWeight: 'bold' }}>{metrics.uptime}</div>
            </div>
            <div style={{ background: 'rgba(0,255,255,0.1)', padding: '20px', borderRadius: '10px' }}>
              <div style={{ color: '#888', fontSize: '14px' }}>Memory Usage</div>
              <div style={{ color: '#ffaa00', fontSize: '32px', fontWeight: 'bold' }}>{metrics.memoryUsage}</div>
            </div>
          </div>
        </div>

        {/* Service Info */}
        <div style={{
          background: 'rgba(26,26,46,0.8)',
          borderRadius: '15px',
          padding: '30px',
          border: '1px solid #ff00ff'
        }}>
          <h2 style={{ color: '#ff00ff', marginBottom: '25px', display: 'flex', alignItems: 'center', gap: '10px' }}>
            <Cpu size={24} />
            Service Information
          </h2>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '15px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', padding: '15px', background: 'rgba(255,0,255,0.1)', borderRadius: '8px' }}>
              <span style={{ color: '#888' }}>Service Name</span>
              <span style={{ color: 'white' }}>core-brain</span>
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', padding: '15px', background: 'rgba(255,0,255,0.1)', borderRadius: '8px' }}>
              <span style={{ color: '#888' }}>Port</span>
              <span style={{ color: 'white' }}>52040</span>
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', padding: '15px', background: 'rgba(255,0,255,0.1)', borderRadius: '8px' }}>
              <span style={{ color: '#888' }}>Type</span>
              <span style={{ color: 'white' }}>Python FastAPI</span>
            </div>
            <div style={{ display: 'flex', justifyContent: 'space-between', padding: '15px', background: 'rgba(255,0,255,0.1)', borderRadius: '8px' }}>
              <span style={{ color: '#888' }}>Role</span>
              <span style={{ color: 'white' }}>Central Orchestrator</span>
            </div>
          </div>
        </div>

        {/* Connected Services */}
        <div style={{
          background: 'rgba(26,26,46,0.8)',
          borderRadius: '15px',
          padding: '30px',
          border: '1px solid #00ff88'
        }}>
          <h2 style={{ color: '#00ff88', marginBottom: '25px', display: 'flex', alignItems: 'center', gap: '10px' }}>
            <Network size={24} />
            Connected Services
          </h2>
          <div style={{ display: 'flex', flexDirection: 'column', gap: '10px' }}>
            {['Event Bus', 'Knowledge Graph', 'Memory', 'Reasoning Engine', 'Learning Engine'].map((svc, i) => (
              <div key={i} style={{
                display: 'flex',
                justifyContent: 'space-between',
                alignItems: 'center',
                padding: '12px 15px',
                background: 'rgba(0,255,136,0.1)',
                borderRadius: '8px'
              }}>
                <span>{svc}</span>
                <span style={{ color: '#00ff88', fontSize: '12px' }}>● Connected</span>
              </div>
            ))}
          </div>
        </div>

        {/* Live Logs */}
        <div style={{
          background: 'rgba(26,26,46,0.8)',
          borderRadius: '15px',
          padding: '30px',
          border: '1px solid #ffaa00'
        }}>
          <h2 style={{ color: '#ffaa00', marginBottom: '25px' }}>Live Logs</h2>
          <div style={{
            background: '#0a0a0a',
            borderRadius: '8px',
            padding: '15px',
            height: '200px',
            overflow: 'auto',
            fontFamily: 'monospace',
            fontSize: '12px'
          }}>
            {logs.length === 0 ? (
              <span style={{ color: '#666' }}>Waiting for logs...</span>
            ) : (
              logs.map((log, i) => (
                <div key={i} style={{ color: log.includes('FAILED') || log.includes('error') ? '#ff0055' : '#00ff88', marginBottom: '5px' }}>
                  {log}
                </div>
              ))
            )}
          </div>
        </div>
      </div>
    </div>
  );
}
