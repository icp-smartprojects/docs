# ============================================================================
# ACTIVE LEARNING ENDPOINTS
# ============================================================================

@app.post("/api/v1/active/uncertainty/detect")
async def detect_uncertainty(
    prediction_scores: Dict[str, float],
    context: Dict[str, Any]
):
    """Detect if current situation is uncertain"""
    try:
        situation = uncertainty_learner.detect_uncertainty(
            prediction_scores, context
        )
        
        if situation:
            # Generate query to resolve uncertainty
            query = query_generator.generate_query(situation)
            
            return {
                "uncertain": True,
                "uncertainty_score": situation.uncertainty_score,
                "conflicting_concepts": situation.conflicting_concepts,
                "query": {
                    "id": query.query_id,
                    "question": query.question,
                    "options": query.options
                }
            }
        else:
            return {"uncertain": False}
    
    except Exception as e:
        logger.error(f"Error detecting uncertainty: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.post("/api/v1/active/query/answer")
async def answer_query(query_id: str, answer: str):
    """Answer an active learning query"""
    try:
        success = query_generator.answer_query(query_id, answer)
        
        if not success:
            raise HTTPException(status_code=404, detail="Query not found")
        
        return {"status": "success", "query_id": query_id}
    
    except Exception as e:
        logger.error(f"Error answering query: {e}")
        raise HTTPException(status_code=500, detail=str(e))


