@app.get("/health")
async def health_check():
    """Health check endpoint"""
    return {
        "status": "healthy",
        "service": "learning-engine",
        "port": settings.PORT,
        "timestamp": datetime.utcnow().isoformat()
    }


@app.get("/ready")
async def readiness_check():
    """Readiness check - verifies event-bus if configured."""
    checks = {}
    targets = {
        "event_bus": (EVENT_BUS_URL, "/health"),
        "shape_engine": (SHAPE_ENGINE_URL, "/health"),
        "meaning_engine": (settings.MEANING_ENGINE_URL, "/ready"),
        "reasoning_engine": (REASONING_ENGINE_URL, "/ready"),
        "policy_engine": (POLICY_ENGINE_URL, "/ready"),
        "simulation": (SIMULATION_ENGINE_URL, "/ready"),
    }
    async with httpx.AsyncClient(timeout=2.0) as client:
        for name, (base, path) in targets.items():
            if not base:
                continue
            try:
                resp = await client.get(f"{base.rstrip('/')}{path}")
                checks[name] = resp.status_code < 500
            except Exception:
                checks[name] = False
    ready = all(checks.values()) if checks else True
    if not ready:
        return JSONResponse(status_code=503, content={"ready": False, "checks": checks})
    return {"ready": True, "checks": checks}


# ============================================================================
# EVENT BUS CONSUMER (multi-topic)
# ============================================================================

async def _consume_topic(topic: str):
    if not EVENT_BUS_URL:
        return
    client: httpx.AsyncClient = app.state.event_bus_client
    url = f"{EVENT_BUS_URL}/api/v1/stream"
    params = {"topic": topic}
    while not app.state.stop_event.is_set():
        try:
            async with client.stream("GET", url, params=params) as resp:
                if resp.status_code != 200:
                    await asyncio.sleep(1.0)
                    continue
                async for line in resp.aiter_lines():
                    if app.state.stop_event.is_set():
                        break
                    if not line or not line.startswith("data:"):
                        continue
                    raw = line.replace("data:", "", 1).strip()
                    try:
                        data = json.loads(raw)
                        payload = data.get("payload") if isinstance(data, dict) else data
                        state = app.state.topic_state.setdefault(topic, {"count": 0, "last_event": None})
                        state["count"] += 1
                        state["last_event"] = payload
                        await ingest_learning_event(topic, payload, source="event-bus")
                    except Exception:
                        logger.debug("event_bus_parse_failed", extra={"topic": topic})
        except asyncio.CancelledError:
            break
        except Exception:
            await asyncio.sleep(1.0)


@app.on_event("startup")
async def _startup_event_bus():
    app.state.event_bus_client = httpx.AsyncClient(timeout=None)
    app.state.stop_event = asyncio.Event()
    app.state.topic_state = {}
    _ensure_state()
    if EVENT_BUS_URL:
        app.state.event_tasks = [
            asyncio.create_task(_consume_topic(topic)) for topic in LEARNING_EVENT_TOPICS
        ]


@app.on_event("shutdown")
async def _shutdown_event_bus():
    app.state.stop_event.set()
    tasks = getattr(app.state, "event_tasks", [])
    for task in tasks:
        task.cancel()
    if tasks:
        await asyncio.gather(*tasks, return_exceptions=True)
    client = getattr(app.state, "event_bus_client", None)
    if client:
        await client.aclose()


@app.get("/api/v1/simulation/outcomes")
async def get_simulation_outcomes_state():
    """Returns a summary of simulation outcomes received from event-bus."""
    return getattr(app.state, "topic_state", {}).get("simulation.outcomes", {"count": 0, "last_event": None})


# ============================================================================
# SUPERVISED LEARNING ENDPOINTS
# ============================================================================

class LearningEventIn(BaseModel):
    event_type: str
    source: Optional[str] = "external"
    payload: Dict[str, Any] = {}
    evidence_ids: List[str] = []


class FreezeRequest(BaseModel):
    freeze: bool = True
    reason: Optional[str] = None


class RollbackRequest(BaseModel):
    version: int


@app.post("/api/v1/learning/events/ingest")
async def ingest_event(event: LearningEventIn):
    """Ingest generic learning events (shape/meaning/reasoning/simulation)."""
    try:
        _ensure_state()
        record = await ingest_learning_event(
            event_type=event.event_type,
            payload=event.payload,
            source=event.source or "external",
        )
        return {"status": "ok", "record": record}
    except Exception as e:
        logger.error(f"Error ingesting learning event: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@app.get("/api/v1/learning/audit")
async def get_audit_log(limit: int = 100):
    """Return recent audit records."""
    _ensure_state()
    records = list(app.state.audit_log)[-limit:]
    return {"count": len(records), "records": records}


@app.get("/api/v1/learning/calibration")
async def get_calibration_state():
    """Return calibration tables and drift status."""
    _ensure_state()
    return {
        "version": app.state.model_version,
        "frozen": app.state.learning_frozen,
        "freeze_reason": app.state.freeze_reason,
        "calibration": app.state.calibration,
        "drift": {
            "window": list(app.state.outcome_window),
            "baseline_success_rate": app.state.baseline_success_rate,
        },
    }


@app.get("/api/v1/learning/version")
async def get_version_state():
    """Return version history."""
    _ensure_state()
    return {
        "current_version": app.state.model_version,
        "history": app.state.model_history[-50:],
        "config_hash": _config_hash(app.state.calibration, app.state.model_version),
    }


@app.post("/api/v1/learning/rollback")
async def rollback_version(request: RollbackRequest):
    """Rollback calibration state to a previous version."""
    _ensure_state()
    target = next((h for h in app.state.model_history if h["version"] == request.version), None)
    if not target:
        raise HTTPException(status_code=404, detail="Version not found")
    app.state.calibration = json.loads(json.dumps(target["calibration"], default=str))
    app.state.model_version = request.version
    app.state.learning_frozen = True
    app.state.freeze_reason = "rollback_applied"
    app.state.freeze_timestamp = datetime.utcnow().isoformat()
    record = _record_audit(
        event_type="ROLLBACK_APPLIED",
        source="api",
        payload={"version": request.version},
        changes={"frozen": True},
    )
    await _publish_learning_event("learning.rollback", record)
    return {"status": "rolled_back", "version": request.version, "record": record}


@app.post("/api/v1/learning/freeze")
async def freeze_learning(req: FreezeRequest):
    """Freeze or unfreeze learning updates."""
    _ensure_state()
    app.state.learning_frozen = bool(req.freeze)
    app.state.freeze_reason = req.reason or ("manual_freeze" if req.freeze else None)
    app.state.freeze_timestamp = datetime.utcnow().isoformat() if req.freeze else None
    record = _record_audit(
        event_type="FREEZE_TOGGLE",
        source="api",
        payload={"freeze": req.freeze, "reason": req.reason},
        changes={"frozen": app.state.learning_frozen},
    )
    await _publish_learning_event("learning.freeze", record)
    return {"status": "ok", "frozen": app.state.learning_frozen, "record": record}


@app.get("/api/v1/learning/freeze")
async def get_freeze_state():
    _ensure_state()
    return {
        "frozen": app.state.learning_frozen,
        "reason": app.state.freeze_reason,
        "timestamp": app.state.freeze_timestamp,
    }


# ============================================================================
# REAL BABY-LEARNING LOOP ENDPOINTS
# ============================================================================

class FeedbackIn(BaseModel):
    """Ingest feedback for the real learning loop."""
    shape_id: str
    shape_type: str
    feedback_type: str  # "accept", "reject", "adjust", "relabel"
    symbol: str = ""
    timeframe: str = ""
    before_geometry: Optional[Dict[str, Any]] = None
    after_geometry: Optional[Dict[str, Any]] = None
    context_candle_ids: List[str] = []
    reason: str = ""


@app.post("/api/v1/learning/feedback")
async def submit_feedback(fb: FeedbackIn):
    """Submit accept/reject/adjust feedback → updates detector weights."""
    try:
        ft = LoopFeedbackType(fb.feedback_type.lower())
    except ValueError:
        raise HTTPException(
            status_code=400,
            detail=f"Invalid feedback_type '{fb.feedback_type}'. "
                   f"Must be one of: accept, reject, adjust, relabel",
        )

    record = FeedbackRecord(
        id=f"fb_{uuid.uuid4().hex[:12]}",
        feedback_type=ft,
        shape_id=fb.shape_id,
        shape_type=fb.shape_type.upper(),
        symbol=fb.symbol,
        timeframe=fb.timeframe.upper(),
        before_geometry=fb.before_geometry,
        after_geometry=fb.after_geometry,
        context_candle_ids=fb.context_candle_ids,
        reason=fb.reason,
    )
    result = _learning_loop.ingest_feedback(record)

    # Also nudge the inline calibration to keep both systems in sync
    _ensure_state()
    if not app.state.learning_frozen:
        delta_map = {
            "accept": 0.04,
            "reject": -0.06,
            "adjust": -0.02,
            "relabel": -0.04,
        }
        delta = delta_map.get(fb.feedback_type.lower(), 0.0)
        if fb.shape_type:
            _apply_delta(app.state.calibration["by_shape_type"], fb.shape_type.upper(), delta)
        if fb.timeframe:
            _apply_delta(app.state.calibration["by_timeframe"], fb.timeframe.upper(), delta)
        await _bump_version(
            reason=f"feedback_{fb.feedback_type}",
            changes={"feedback": result},
        )

    return {"status": "ok", "result": result}


@app.get("/api/v1/learning/weights/{shape_type}/{timeframe}")
