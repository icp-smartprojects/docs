# ============================================================================
# LEARNING STATE + AUDIT
# ============================================================================

TF_AUTHORITY = {
    "1S": 1,
    "2S": 1,
    "1M": 2,
    "2M": 3,
    "3M": 4,
    "5M": 5,
    "15M": 6,
    "30M": 7,
    "1H": 8,
    "4H": 9,
    "1D": 10,
    "1W": 11,
}


def _clamp(value: float, lo: float = 0.0, hi: float = 1.0) -> float:
    return max(lo, min(hi, value))


def _config_hash(calibration: Dict[str, Any], version: int) -> str:
    raw = json.dumps({"version": version, "calibration": calibration}, sort_keys=True, default=str)
    return hashlib.sha256(raw.encode("utf-8")).hexdigest()


def _ensure_state():
    if getattr(app.state, "learning_state_initialized", False):
        return
    app.state.learning_state_initialized = True
    app.state.learning_frozen = False
    app.state.freeze_reason = None
    app.state.freeze_timestamp = None
    app.state.policy_violation_count = 0
    app.state.model_version = 1
    app.state.model_history = []
    app.state.calibration = {
        "by_shape_type": {},
        "by_timeframe": {},
        "by_detector": {},
    }
    app.state.audit_log = deque(maxlen=settings.LEARNING_AUDIT_MAX)
    app.state.outcome_window = deque(maxlen=settings.LEARNING_DRIFT_MIN_OUTCOMES)
    app.state.baseline_success_rate = None


def _record_audit(
    event_type: str,
    source: str,
    payload: Dict[str, Any],
    changes: Optional[Dict[str, Any]] = None,
    evidence_ids: Optional[List[str]] = None,
    version: Optional[int] = None,
) -> Dict[str, Any]:
    record = {
        "record_id": f"aud_{uuid.uuid4().hex[:12]}",
        "event_type": event_type,
        "source": source,
        "timestamp": datetime.utcnow().isoformat(),
        "evidence_ids": evidence_ids or [],
        "changes": changes or {},
        "payload": payload,
        "version": version if version is not None else app.state.model_version,
        "config_hash": _config_hash(app.state.calibration, app.state.model_version),
    }
    app.state.audit_log.append(record)
    return record


async def _bump_version(reason: str, changes: Dict[str, Any]) -> Dict[str, Any]:
    app.state.model_version += 1
    snapshot = {
        "version": app.state.model_version,
        "timestamp": datetime.utcnow().isoformat(),
        "reason": reason,
        "changes": changes,
        "calibration": json.loads(json.dumps(app.state.calibration, default=str)),
        "config_hash": _config_hash(app.state.calibration, app.state.model_version),
    }
    app.state.model_history.append(snapshot)
    # Publish feedback loop on every version bump
    await _publish_feedback_loop()
    return snapshot


def _apply_delta(bucket: Dict[str, float], key: str, delta: float) -> Dict[str, float]:
    max_delta = settings.LEARNING_MAX_PARAM_DELTA
    delta = max(-max_delta, min(max_delta, delta))
    old = float(bucket.get(key, 0.5))
    new = _clamp(old + delta, 0.0, 1.0)
    bucket[key] = new
    return {"key": key, "old": old, "new": new, "delta": new - old}


def _tf_weight(timeframe: Optional[str]) -> float:
    if not timeframe:
        return 1.0
    tf = str(timeframe).upper()
    return float(TF_AUTHORITY.get(tf, 1))


async def _publish_learning_event(topic: str, payload: Dict[str, Any]) -> None:
    if not EVENT_BUS_URL or not LEARNING_PUBLISH_ENABLED:
        return
    try:
        import uuid as _uuid
        event_id = str(_uuid.uuid4())
        async with httpx.AsyncClient(timeout=5.0) as client:
            await client.post(
                f"{EVENT_BUS_URL}/api/v1/publish",
                json={
                    "topic": topic,
                    "event_type": topic.upper().replace(".", "_"),
                    "source": "learning-engine",
                    "timestamp": datetime.utcnow().isoformat(),
                    "correlation_id": payload.get("correlation_id", event_id),
                    "causation_id": payload.get("causation_id", ""),
                    "schema_version": "1.0.0",
                    "payload": payload,
                    "headers": {"source_service": "learning-engine"},
                },
            )
    except Exception as exc:
        logger.warning("learning_event_publish_failed", error=str(exc), topic=topic)


async def _fetch_shape_details(shape_id: str) -> Optional[Dict[str, Any]]:
    if not SHAPE_ENGINE_URL:
        return None
    try:
        async with httpx.AsyncClient(timeout=3.0) as client:
            resp = await client.get(f"{SHAPE_ENGINE_URL}/api/v1/shapes/{shape_id}")
            if resp.status_code >= 400:
                return None
            return resp.json()
    except Exception:
        return None


def _update_drift_window(success_degree: float) -> None:
    app.state.outcome_window.append(success_degree)
    if len(app.state.outcome_window) < settings.LEARNING_DRIFT_MIN_OUTCOMES:
        return
    success_rate = sum(1 for s in app.state.outcome_window if s > 0.25) / len(app.state.outcome_window)
    if app.state.baseline_success_rate is None:
        app.state.baseline_success_rate = success_rate
        return
    if success_rate < settings.LEARNING_DRIFT_MIN_SUCCESS_RATE:
        app.state.learning_frozen = True
        app.state.freeze_reason = "success_rate_below_threshold"
        app.state.freeze_timestamp = datetime.utcnow().isoformat()
    elif (app.state.baseline_success_rate - success_rate) > settings.LEARNING_DRIFT_DROP:
        app.state.learning_frozen = True
        app.state.freeze_reason = "success_rate_drop"
        app.state.freeze_timestamp = datetime.utcnow().isoformat()


async def _apply_shape_signal(event_type: str, payload: Dict[str, Any]) -> Dict[str, Any]:
    changes = {"shape": [], "timeframe": []}
    if app.state.learning_frozen:
        return {"status": "frozen", "changes": changes}

    shape_id = payload.get("shape_id") or payload.get("id")
    details = payload
    if shape_id:
        shape_details = await _fetch_shape_details(str(shape_id))
        if shape_details:
            details = {**details, **shape_details}

    shape_type = str(details.get("shape_type") or "").upper()
    timeframe = str(details.get("timeframe") or "").upper()

    delta_map = {
        "SHAPE_CONFIRMED": 0.04,
        "SHAPE_TOUCHED": 0.01,
        "SHAPE_UPDATED": 0.01,
        "SHAPE_CREATED": 0.00,
        "SHAPE_INVALIDATED": -0.06,
        "SHAPE_SUPPRESSED": -0.05,
        "SHAPE_EXPIRED": -0.03,
        "SHAPE_DEDUPLICATED": -0.02,
        "SHAPE_FEEDBACK_RECEIVED": 0.05,
    }
    base_delta = delta_map.get(event_type, 0.0)

    # Feedback-specific adjustment
    feedback_signal = payload.get("learning_signal")
    if feedback_signal is not None:
        try:
            base_delta = float(feedback_signal) * 0.05
        except Exception:
            pass

    weight = _tf_weight(timeframe)
    base_delta = max(-settings.LEARNING_MAX_EVENT_DELTA, min(settings.LEARNING_MAX_EVENT_DELTA, base_delta))
    delta = base_delta * (1.0 + (weight / 10.0))

    if shape_type:
        changes["shape"].append(_apply_delta(app.state.calibration["by_shape_type"], shape_type, delta))
    if timeframe:
        changes["timeframe"].append(_apply_delta(app.state.calibration["by_timeframe"], timeframe, delta))

    return {"status": "updated", "changes": changes, "shape_type": shape_type, "timeframe": timeframe}


def _apply_policy_violation(payload: Dict[str, Any]) -> None:
    app.state.policy_violation_count += 1
    if app.state.policy_violation_count >= settings.LEARNING_POLICY_VIOLATION_FREEZE:
        app.state.learning_frozen = True
        app.state.freeze_reason = "policy_violation_spike"
        app.state.freeze_timestamp = datetime.utcnow().isoformat()


async def _publish_feedback_loop() -> None:
    """Publish calibration feedback to perception, meaning, and shape engines.

    Emits three events every time the model version bumps:
      - learning.thresholds  -> perception (detection sensitivity per detector)
      - learning.calibration -> meaning engine (per-shape / per-timeframe weights)
      - learning.validity    -> shape engine (strictness per shape type)
    """
    cal = app.state.calibration
    version = app.state.model_version
    ts = datetime.utcnow().isoformat()
    correlation_id = f"feedback_{version}_{uuid.uuid4().hex[:8]}"

    # --- 1. Thresholds for Perception ----------------------------------
    # Translate per-detector calibration into detection thresholds.
    # Higher calibration value -> the detector is performing well -> we can
    # tighten the threshold (raise it).  Lower -> relax it.
    detector_thresholds: Dict[str, float] = {}
    for detector, cal_value in cal.get("by_detector", {}).items():
        # Map calibration [0..1] to a threshold band [0.3 .. 0.9]
        detector_thresholds[detector] = round(_clamp(0.3 + cal_value * 0.6, 0.3, 0.9), 4)

    await _publish_learning_event("learning.thresholds", {
        "version": version,
        "timestamp": ts,
        "correlation_id": correlation_id,
        "thresholds": detector_thresholds,
        "by_timeframe": {
            tf: round(_clamp(0.3 + v * 0.6, 0.3, 0.9), 4)
            for tf, v in cal.get("by_timeframe", {}).items()
        },
    })

    # --- 2. Calibration for Meaning Engine -----------------------------
    await _publish_learning_event("learning.calibration", {
        "version": version,
        "timestamp": ts,
        "correlation_id": correlation_id,
        "by_shape_type": cal.get("by_shape_type", {}),
        "by_timeframe": cal.get("by_timeframe", {}),
        "by_detector": cal.get("by_detector", {}),
    })

    # --- 3. Validity strictness for Shape Engine -----------------------
    # Higher shape-type calibration -> the shape is reliable -> we can
    # be stricter about what counts as valid.
    shape_validity: Dict[str, float] = {}
    for stype, cal_value in cal.get("by_shape_type", {}).items():
        # Map [0..1] -> strictness [0.4 .. 0.95]
        shape_validity[stype] = round(_clamp(0.4 + cal_value * 0.55, 0.4, 0.95), 4)

    await _publish_learning_event("learning.validity", {
        "version": version,
        "timestamp": ts,
        "correlation_id": correlation_id,
        "shape_validity": shape_validity,
        "by_timeframe": {
            tf: round(_clamp(0.4 + v * 0.55, 0.4, 0.95), 4)
            for tf, v in cal.get("by_timeframe", {}).items()
        },
    })

    logger.info(
        "feedback_loop_published",
        extra={"version": version, "detectors": len(detector_thresholds), "shapes": len(shape_validity)},
    )


def _extract_simulation_score(payload: Dict[str, Any]) -> Optional[float]:
    if not payload:
        return None
    inner = payload.get("payload") if isinstance(payload, dict) else None
    if inner and isinstance(inner, dict):
        payload = inner
    result = payload.get("result") if isinstance(payload, dict) else None
    if not result:
        return None
    branches = result.get("branches") or []
    if not branches:
        return None
    branch = branches[0]
    reward = float(branch.get("reward") or 0.0)
    penalty = float(branch.get("penalty") or 0.0)
    return max(-1.0, min(1.0, reward - penalty))


async def ingest_learning_event(event_type: str, payload: Dict[str, Any], source: str = "event-bus") -> Dict[str, Any]:
    _ensure_state()
    changes: Dict[str, Any] = {}

    if event_type.startswith("SHAPE_"):
        changes = await _apply_shape_signal(event_type, payload)
        if changes.get("status") == "updated":
            snapshot = await _bump_version(reason=f"{event_type.lower()}_update", changes=changes)
            await _publish_learning_event("learning.model_release", snapshot)
            await _publish_learning_event("learning.updates", changes)

    elif event_type == "simulation.outcomes":
        score = _extract_simulation_score(payload)
        if score is not None:
            _update_drift_window(score)
            if app.state.learning_frozen and app.state.freeze_reason:
                await _publish_learning_event(
                    "learning.freeze",
                    {
                        "reason": app.state.freeze_reason,
                        "timestamp": app.state.freeze_timestamp,
                    },
                )
        changes = {"simulation_score": score}

    elif event_type == "reasoning.decisions":
        # ----- Extract prediction record from reasoning decision -----
        shape_type = str(payload.get("shape_type") or "").upper()
        timeframe  = str(payload.get("timeframe") or "").upper()
        bias       = payload.get("bias") or payload.get("direction") or "NEUTRAL"
        confidence = float(payload.get("confidence") or payload.get("score") or 0.5)
        decision_ts = payload.get("timestamp") or datetime.utcnow().isoformat()

        prediction = {
            "prediction_id": f"pred_{uuid.uuid4().hex[:12]}",
            "shape_type": shape_type,
            "timeframe": timeframe,
            "bias": str(bias).upper(),
            "confidence": _clamp(confidence),
            "timestamp": decision_ts,
            "source_event": payload.get("decision_id") or payload.get("id"),
        }

        # Store the latest prediction on app state for tracking
        if not hasattr(app.state, "predictions"):
            app.state.predictions = deque(maxlen=500)
        app.state.predictions.append(prediction)

        # Update calibration based on decision confidence
        cal_changes: Dict[str, list] = {"shape": [], "timeframe": [], "detector": []}
        if not app.state.learning_frozen:
            # Positive confidence -> small positive nudge; low confidence -> negative
            delta = (confidence - 0.5) * settings.LEARNING_RATE_REINFORCEMENT
            weight = _tf_weight(timeframe)
            delta = delta * (1.0 + (weight / 10.0))

            if shape_type:
                cal_changes["shape"].append(
                    _apply_delta(app.state.calibration["by_shape_type"], shape_type, delta)
                )
            if timeframe:
                cal_changes["timeframe"].append(
                    _apply_delta(app.state.calibration["by_timeframe"], timeframe, delta)
                )
            detector = str(payload.get("detector") or "").upper()
            if detector:
                cal_changes["detector"].append(
                    _apply_delta(app.state.calibration["by_detector"], detector, delta)
                )

            if any(cal_changes.values()):
                snapshot = await _bump_version(
                    reason="reasoning_decision_update",
                    changes=cal_changes,
                )
                await _publish_learning_event("learning.model_release", snapshot)
                await _publish_learning_event("learning.updates", cal_changes)

        changes = {"prediction": prediction, **cal_changes}

    elif event_type == "meaning.state":
        changes = {"meaning_event": True}

    elif event_type == "policy.violations":
        _apply_policy_violation(payload)
        changes = {"policy_violation_count": app.state.policy_violation_count}
        if app.state.learning_frozen and app.state.freeze_reason:
            await _publish_learning_event(
                "learning.freeze",
                {
                    "reason": app.state.freeze_reason,
                    "timestamp": app.state.freeze_timestamp,
                },
            )

    record = _record_audit(
        event_type=event_type,
        source=source,
        payload=payload,
        changes=changes,
    )
    return record


