# ============================================================================
# REINFORCEMENT LEARNING ENDPOINTS
# ============================================================================

@app.post("/api/v1/reinforcement/outcome/learn")
async def learn_from_outcome(outcome: Outcome):
    """Learn from action outcome"""
    try:
        _ensure_state()
        _update_drift_window(outcome.success_degree)
        if app.state.learning_frozen and app.state.freeze_reason:
            await _publish_learning_event(
                "learning.freeze",
                {
                    "reason": app.state.freeze_reason,
                    "timestamp": app.state.freeze_timestamp,
                },
            )

        if app.state.learning_frozen:
            record = _record_audit(
                event_type="OUTCOME_INGESTED_FROZEN",
                source="api",
                payload=outcome.to_dict(),
                changes={"frozen": True, "reason": app.state.freeze_reason},
            )
            return {
                "status": "frozen",
                "outcome_id": outcome.outcome_id,
                "analysis": None,
                "audit": record,
                "reason": app.state.freeze_reason,
            }

        analysis = outcome_learner.learn_from_outcome(outcome)

        # Update beliefs based on outcome
        if outcome.is_success():
            rl_belief_updater.update_from_outcome(outcome)

        # Calibration updates per timeframe/shape_type
        changes = {"timeframe": [], "shape": []}
        timeframe = (outcome.context or {}).get("timeframe")
        shape_type = (outcome.context or {}).get("shape_type")
        delta = float(outcome.success_degree) * settings.LEARNING_RATE_REINFORCEMENT
        if timeframe:
            changes["timeframe"].append(
                _apply_delta(app.state.calibration["by_timeframe"], str(timeframe).upper(), delta)
            )
        if shape_type:
            changes["shape"].append(
                _apply_delta(app.state.calibration["by_shape_type"], str(shape_type).upper(), delta)
            )

        if changes["timeframe"] or changes["shape"]:
            snapshot = await _bump_version(reason="outcome_learning", changes=changes)
            await _publish_learning_event("learning.model_release", snapshot)
            await _publish_learning_event("learning.updates", changes)

        record = _record_audit(
            event_type="OUTCOME_LEARNED",
            source="api",
            payload=outcome.to_dict(),
            changes=changes,
        )

        return {
            "status": "success",
            "outcome_id": outcome.outcome_id,
            "analysis": analysis,
            "audit": record,
        }
    except Exception as e:
        logger.error(f"Error learning from outcome: {e}")
        raise HTTPException(status_code=500, detail=str(e))


